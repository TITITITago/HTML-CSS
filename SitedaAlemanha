--------CSS----------

/* Configurações Gerais */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    line-height: 1.6;
    background-color: #f4f4f4;
    color: #333;
}

.container {
    max-width: 1980px;
    margin: 20px auto;
    background: #fff;
    padding: 20px;
    border-radius: 8px;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
}

/* Cabeçalho e Menu */
header.titulo {
    text-align: center;
    border-bottom: 3px solid #ffce00;
    /* Cor da bandeira da Alemanha */
    padding-bottom: 20px;
    margin-bottom: 20px;
}

header h1 {
    color: #000;
    text-transform: uppercase;
    letter-spacing: 2px;
}

.menu ul {
    list-style: none;
    display: flex;
    justify-content: center;
    gap: 20px;
    margin-top: 15px;
}

.menu a {
    text-decoration: none;
    color: #d00;
    /* Cor da bandeira da Alemanha */
    font-weight: bold;
    transition: color 0.3s;
}

.menu a:hover {
    color: #ffce00;
}

/* Layout Principal (Main) */
main {
    display: flex;
    gap: 30px;
    margin-top: 20px;
}

.conteudo {
    flex: 3;
    /* Ocupa 3 partes do espaço */
}

aside {
    flex: 1;
    /* Ocupa 1 parte do espaço */
    background: #f9f9f9;
    padding: 15px;
    border-radius: 5px;
    height: fit-content;
    border-left: 5px solid #000;
}

/* Artigos e Seções */
article {
    margin-bottom: 40px;
}

h2,
h3 {
    margin-bottom: 15px;
    color: #222;
}

p {
    margin-bottom: 15px;
    text-align: justify;
}

/* Imagens */

aside img {
    margin: 15px 0;
    display: flex;
}

.conteudo article img {
    width: 100%;
    display: flex;
    height: auto;
    border-radius: 5px;
}

/* Botões/Links "Confira" */
article a {
    display: inline-block;
    padding: 8px 15px;
    background-color: #000;
    color: #fff;
    text-decoration: none;
    border-radius: 4px;
    font-size: 0.9em;
}

article a:hover {
    background-color: #333;
}

/* Barra Lateral (Aside) */
aside ul {
    list-style: none;
    margin: 15px 0;
}

aside li {
    padding: 5px 0;
    border-bottom: 1px solid #ddd;
}

/* Rodapé */
footer {
    margin-top: 50px;
    font-size: 0.9em;
    color: #666;
}

address {
    font-style: normal;
    margin-top: 10px;
    text-align: center;
}

/* Responsividade (Para Celulares) */
@media (max-width: 768px) {
    .container {
        flex-direction: column;
    }

    .menu ul {
        flex-direction: column;
        align-items: center;
        gap: 10px;
    }

    @media (max-width: 320px) {
        .container {
            flex-direction: column;
        }

        .menu ul {
            flex-direction: column;
            align-items: center;
            gap: 10px;
        }
    }
}


