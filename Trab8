CSS----------------------------------------------------------
/* --- Reset --- */
* {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
}

/* --- Layout principal --- */
main {
    display: flex;
    gap: 20px;
}

/* --- Corpo da página --- */
body {
    font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    background-color: #f0f2f5;
    color: #333;
    line-height: 1.6;
    max-width: 1980px;
    margin-right:auto;
    margin-left:auto;
    display: block;
    justify-content: center;
    padding: 40px 20px;
}

/* --- Container --- */

.titulo {
    background: 
        linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.5)),
        url('https://cdn0.umcomo.com.br/pt/posts/6/4/7/qual_o_significado_das_cores_da_bandeira_da_alemanha_13746_600.jpg');

    background-size: contain;
    background-position: center;

    height: 300px; 
}

/* --- Conteúdo e Aside --- */
.conteudo {
    width: 80%;
}

.menu {
    background-color: #991313;
    display: flex;
    justify-content: center;
    padding: 15px 0;
}
.menu a {
    color: white;
    text-decoration: none;
    padding: 15px 20px;
    text-align: center;
    font-size: 20px;
    transition: 0.3s;
    border-radius: 10px;
}

aside {
    width: 20%;
    padding: 15px;
    border: 5px solid #991313;
    background: #f8f9fa;
    border-radius: 15px;
}

aside ul {
    list-style: none;
    margin-bottom: 15px;
}

aside li {
    margin-bottom: 8px;
    font-size: 0.95rem;
}


/*LISTA DE PRODUTOS*/
.lista-produtos img {
    width: 150px;
    height: 150px;
    object-fit: cover;
    border-radius: 10px;
}
/* Preço */
.lista-produtos span {
    font-size: 1.2rem;
    font-weight: bold;
    color: #d32f2f;
}

/* Hover */
.lista-produtos li:hover {
    transform: scale(1.02);
}


/*---------------------*/ 

/* --- Imagens --- */
img {
    width: 100%;
    border-radius: 12px;
    margin: 25px 0;
    transition: 0.3s;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
}

img:hover {
    transform: scale(1.03);
    box-shadow: 0 15px 35px rgba(0,0,0,0.2);
}
/*------------------------*/

/* --- Títulos --- */
h1 {
    text-align: center;
    font-size: 2.5rem;
    margin-bottom: 40px;
    border:none
    padding-bottom: 10px;
    color: white; 
}

h2 {
    color: #991313;
    border-left: 6px solid #000;
    padding-left: 15px;
    margin: 35px 0 20px;
}

h3 {
    color: #2c3e50;
    margin: 30px 0 15px;
}

/* --- Artigos --- */
article {
    margin-bottom: 40px;
    padding-bottom: 20px;
    border-bottom: 1px dashed #eee;
}

p {
    margin-bottom: 15px;
    color: #555;
    font-size: 1.1rem;
}


/* --- Links --- */
article a {
    display: inline-block;
    background: #2c3e50;
    color: #fff;
    padding: 12px 25px;
    text-decoration: none;
    border-radius: 8px;
    transition: 0.3s;
}

article a:hover {
    background: #d32f2f;
}


/* --- Rodapé --- */
footer {
    text-align: center;
    margin-top: 50px;
    color: #888;
}

/* Container do Vídeo (Responsivo) */
.videoseila {
    position: relative;
    padding-bottom: 56.25%; /* Proporção 16:9 */
    height: 0;
    overflow: hidden;
    border-radius: 15px;
    box-shadow: 0 15px 35px rgba(0,0,0,0.6);
    border: 4px solid rgba(255, 255, 255, 0.1);
    background: #000;
}

.videoseila iframe {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
}

.subtitle {
    margin-top: 25px;
    font-size: 1.1rem;
    color: #bdc3c7;
    font-style: italic;
}




/* --- Responsivo --- */
@media (max-width: 768px) {
    main {
        flex-direction: column;
    }


}

